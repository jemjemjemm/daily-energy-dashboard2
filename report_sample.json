      "footer.text"
    ],
    "exclude_price_value_if_zero": true,
    "news_article_count_target": 3,
    "summary_item_count_target": 3,
    "issue_count_range": [
      3,
      5
    ],
    "schedule_sort": "time_ascending",
    "chart_required_svg_elements": [
